{
  "definitions": [
    {
      "title": "Carousel",
      "id": "carousel",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Carousel",
              "model": "carousel",
              "filter": "carousel",
              "autoplay": "false",
              "autoplayInterval": "5000",
              "loop": "true",
              "showArrows": "true",
              "showDots": "true",
              "pauseOnHover": "true"
            }
          }
        }
      }
    },
    {
