            "template": {
              "name": "Carousel Slide",
              "model": "carousel-slide"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "carousel",
      "fields": [
        {
          "component": "select",
          "name": "autoplay",
          "label": "Auto-play",
          "value": "false",
          "description": "Automatically advance slides",
          "options": [
            { "name": "Off", "value": "false" },
            { "name": "On", "value": "true" }
          ]
        },
        {
          "component": "text",
          "valueType": "number",
          "name": "autoplayInterval",
          "label": "Auto-play Interval (ms)",
          "value": "5000",
          "description": "Time in milliseconds between slide transitions (e.g. 5000 = 5 s)"
        },
        {
          "component": "select",
          "name": "loop",
          "label": "Loop Slides",
          "value": "true",
          "description": "Loop back to the first slide after the last",
          "options": [
            { "name": "On", "value": "true" },
            { "name": "Off", "value": "false" }
          ]
        },
        {
          "component": "select",
          "name": "showArrows",
          "label": "Show Navigation Arrows",
          "value": "true",
          "description": "Display previous / next arrow buttons",
          "options": [
            { "name": "Show", "value": "true" },
            { "name": "Hide", "value": "false" }
          ]
        },
        {
          "component": "select",
          "name": "showDots",
          "label": "Show Dot Indicators",
          "value": "true",
          "description": "Display the slide position dot indicators",
          "options": [
            { "name": "Show", "value": "true" },
            { "name": "Hide", "value": "false" }
          ]
        },
        {
          "component": "select",
          "name": "pauseOnHover",
          "label": "Pause on Hover",
          "value": "true",
          "description": "Pause auto-play when the user hovers over the carousel",
          "options": [
            { "name": "On", "value": "true" },
            { "name": "Off", "value": "false" }
          ]
        }
      ]
    },
